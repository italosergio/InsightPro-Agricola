{
  "name": "insightpro-agricola",
  "version": "1.0.0",
  "description": "",
  "main": "app.js",
  "scripts": {
    "dev": "vite --host",
    "dev:api": "node scripts/dev-api.js",
    "dev:all": "concurrently -n \"API,VITE\" -c \"green,cyan\" \"npm run dev:api\" \"npm run dev\"",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:unit": "vitest run src/lib src/store src/components",
    "test:integration": "vitest run src/integration",
    "test:snapshot": "vitest run src/snapshots",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/airamlimaff98/InsightPro-Agricola.git"
  },
  "keywords": [],
