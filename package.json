  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/airamlimaff98/InsightPro-Agricola/issues"
  },
  "homepage": "https://github.com/airamlimaff98/InsightPro-Agricola#readme",
  "dependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "chart.js": "^4.5.1",
    "highcharts": "^12.6.0",
    "highcharts-react-official": "^3.2.3",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "lucide-react": "^1.14.0",
    "papaparse": "^5.5.3",
    "pptxgenjs": "^4.0.1",
    "react": "^19.2.5",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.2",
    "vite": "^8.0.10",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.5",
    "concurrently": "^9.2.1",
    "eslint": "^10.3.0",
